{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": ["before 9am on Saturday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchManagers": ["gradle", "gradle-wrapper"],
      "groupName": "Spring Boot",
      "matchPackageNames": [
        "/^org\\.springframework/"
      ]
    },
    {
      "matchPackageNames": [
        "com.google.errorprone:error_prone_core",
        "com.uber.nullaway:nullaway"
      ],
      "groupName": "Static Analysis (Error Prone + NullAway)"
    },
    {
      "matchPackageNames": [
        "org.projectlombok:lombok"
      ],
      "groupName": "Lombok"
    }
  ]
}
